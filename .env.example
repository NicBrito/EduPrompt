# ============================================================
# EduPrompt - Plataforma Educativa com IA
# Configuração de Variáveis de Ambiente
# ============================================================

# Escolha o provedor de IA: "openai", "gemini" ou "anthropic"
AI_PROVIDER=openai

# Chaves de API (preencha apenas a do provedor escolhido)
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Modelo (opcional - usa padrão se não configurado)
# OpenAI: gpt-4o-mini (padrão) ou gpt-4o
# Gemini: gemini-2.0-flash (padrão) ou gemini-2.0-flash-lite
# Anthropic: claude-3-haiku-20240307 (padrão) ou claude-3-sonnet-20240229
AI_MODEL=

# Configuração do servidor Flask (opcional)
FLASK_PORT=5001
FLASK_DEBUG=false

# Cache (em segundos, padrão: 3600 = 1 hora)
CACHE_TTL=3600
